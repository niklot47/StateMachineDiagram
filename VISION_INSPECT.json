      "actions": [
        {
          "qualifier": "EXPR",
          "target": "// === TIMERS ===\n\nTimer_StartUP.IN := STEP_NUMBER = START_UP;\n\nCollection_Timer.IN := STEP_NUMBER = COLLECTION_START\n                    OR STEP_NUMBER = COLLECTION_DELAY\n                    OR STEP_NUMBER = RESET_DISPENSER\n\nCollection_Step_Delay_Timer.IN := STEP_NUMBER = COLLECTION_DELAY\n\n// === EVENTS ===\n\nLid_Is_Open := NOT Sicurezze_Attivate AND NOT Tramoggia_Assente AND NOT Emergenza;\n\nLast_Pill_Recived := (PILL_MAX_NUMBER <> 0 AND PILL_MAX_NUMBER <= PILL_COUNT) \n                  OR (PILL_MAX_NUMBER = 0 AND Collection_Timer);\n\nTimeout_Ciclo := PILL_MAX_NUMBER <> 0 AND Collection_Timer;\n\nTimer_Flashing_On.IN := STEP_NUMBER = FLASHING_ON\n\nTimer_Flashing_Off.IN := STEP_NUMBER = FLASHING_OFF\n\n// === SEMAFORI ===\n\nTimer_Flash_Off.IN := NOT Timer_Flash_On.Q;\nTimer_Flash_On.IN := Timer_Flash_Off.Q;\n\n#_Flash := Timer_Flash_Off.Q AND NOT Timer_Flash_On.Q;\n\n\nSemaforo_Blu := NOT Sicurezze_Attivate \n            OR (Flash AND (NOT PC_Acceso OR Timeout_Ciclo));\n\nSemaforo_Verde := (NOT PAUSE AND RUNNING AND NOT UNLOAD) \n               OR (Flash AND UNLOAD)\n\nSemaforo_Rosso := Emergenza \n               OR Critical_Erorr \n               OR Lid_Is_Open \n               OR Tramoggia_Assente \n               OR ( Flash AND ((PC_Acceso AND NOT MODBUS_CONNECTION) ON_AXIS_ERROR ON_AXIS_ERROR \n                            OR (NOT PC_Acceso AND MODBUS_CONNECTION)))"
        }
      ]
    }
